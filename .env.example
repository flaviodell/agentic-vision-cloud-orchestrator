# LLM
OPENAI_API_KEY=your_key_here

# HuggingFace (to download CV model)
HF_TOKEN=your_token_here

# CV Service — use one of the two options below:
# Option 1: local Docker
# CV_SERVICE_URL=http://localhost:8000
# Option 2: AWS Lambda deploy
CV_SERVICE_URL=https://<API_ID>.execute-api.<REGION>.amazonaws.com/prod

# Vector DB — Pinecone
PINECONE_API_KEY=your_key_here
PINECONE_INDEX=agentic-vet-memory